# Base URL for the backend API consumed by Axios / RTK Query.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# NewsAPI key (server-side only — used by the /api/news route).
# Get one free at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# TMDB credentials (server-side only — used by the /api/movies routes).
# Provide EITHER one. Get them at https://www.themoviedb.org/settings/api
#   - v4 read access token (preferred, sent as a Bearer header):
TMDB_ACCESS_TOKEN=your_tmdb_v4_read_access_token_here
#   - or the v3 API key (sent as an api_key query param):
TMDB_API_KEY=your_tmdb_v3_api_key_here

# The community feed uses the Hacker News (Algolia) API — no key or auth needed.
